[sub_resource type="GDScript" id="GDScript_b4iq0"]
script/source = "extends CharacterBody3D

@onready var anim = $AnimationPlayer
@onready var hit_box = $HitBox
@onready var visuals = $visuals
@onready var near_quilt = $NearQuilt
@onready var navagent = $NavigationAgent3D


signal death

var SPEED = WALK
const WALK = 3.0
const SPRINT = 4.5
const JUMP_VELOCITY = 4.5

var hp = 100

var direction = Vector3()
var lerp_speed = 3.5
var lerp_walk_speed = 8.5 
var gravity = ProjectSettings.get_setting(\"physics/3d/default_gravity\")

func Death():
	queue_free()

func _process(delta):
	if hp <= 0:
		Death()
		
	if self == Main.nearest_enemy:
		near_quilt.visible = true
		if Main.quilt_done:
			hp = 0
			Main.quilt_done = false
	else: near_quilt.visible = false
	
func _physics_process(delta):
	var Position = self.position
	Main.enemy_position = Position
	if not is_on_floor():
		velocity.y -= gravity * delta
		
	if is_on_floor():
		anim.play(\"idle\")
		
		
	move_and_slide()

"

